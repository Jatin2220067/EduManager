# ── Dependencies ──────────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ── Environment (NEVER commit these) ─────────────────────────
.env
backend/.env
*.env.local
*.env.*.local

# ── Build output ──────────────────────────────────────────────
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ── Logs ──────────────────────────────────────────────────────
backend/logs/*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploads ───────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

